{
  "$schema": "https://schema.tauri.app/config/2.json",
  "productName": "LitAtlas",
  "version": "0.2.0",
  "identifier": "com.LitAtlas.viewer",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "LitAtlas — Literature Atlas Viewer",
        "width": 1400,
        "height": 860,
        "minWidth": 1000,
        "minHeight": 640,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}